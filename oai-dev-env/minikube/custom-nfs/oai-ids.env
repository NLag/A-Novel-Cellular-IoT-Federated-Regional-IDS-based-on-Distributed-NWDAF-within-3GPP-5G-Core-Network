# shellcheck shell=bash
NF_NAME=oai-ids
NF_RELEASE=ids
NF_CHART=${ENV_ROOT}/charts/oai-ids
NF_VALUES=${VALUES_ROOT}/ids-dev.yaml
NF_IMAGE_REPOSITORY=local/oai-ids
NF_IMAGE_TAG=dev
NF_IMAGE_PULL_POLICY=Never
NF_DEPLOYMENT_NAME=oai-ids
NF_DEPLOYMENT_SELECTOR=app.kubernetes.io/name=oai-ids,app.kubernetes.io/instance=ids,app.kubernetes.io/component=ids-region
NF_BUILD_CONTEXT=${WORKSPACE_ROOT}/IDS/components/oai-ids
NF_BUILD_DOCKERFILE=${WORKSPACE_ROOT}/IDS/components/oai-ids/docker/Dockerfile.ids
NF_BUILD_TARGET=oai-ids
